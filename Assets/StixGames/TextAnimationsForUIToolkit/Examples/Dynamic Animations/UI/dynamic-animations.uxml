    <Style src="project://database/Assets/StixGames/TextAnimationsForUIToolkit/Examples/Dynamic%20Animations/UI/dynamic-animations.uss?fileID=7433441132597879392&amp;guid=991385eda828c8447b013a384dac0293&amp;type=3#dynamic-animations" />
