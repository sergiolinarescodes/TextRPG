            <TextAnimationsForUIToolkit.AnimatedButton settings="project://database/Assets/StixGames/TextAnimationsForUIToolkit/Examples/Dynamic%20Animations/Dynamic%20Animation%20Settings.asset?fileID=11400000&amp;guid=2b25b33d9375c0b4cbd1f2d5560dcda7&amp;type=2#Dynamic Animation Settings" text="&lt;bounce a=0&gt;Bounce&lt;/bounce&gt;" name="bounce" class="dynamic-button" />
