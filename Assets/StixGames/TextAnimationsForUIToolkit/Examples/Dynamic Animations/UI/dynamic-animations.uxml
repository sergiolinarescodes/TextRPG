    <ui:VisualElement style="background-color: rgba(0, 0, 0, 0); justify-content: center; align-items: center;">
        <ui:Label tabindex="-1" text="For simplicity, the buttons use a single animation per button. This makes it necessary to reset some of the animation on click.&#10;A more complex solution would be layering the animations by dynamically adding and removing animations from the buttons." display-tooltip-when-elided="true" style="font-size: 18px; color: rgb(255, 255, 255); -unity-text-align: upper-center; margin-left: 8px; margin-right: 8px; margin-top: 8px; margin-bottom: 8px;" />
