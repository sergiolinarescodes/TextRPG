--- !u!114 &1429439698
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1429439697}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c85a5c318752472ab1e80ee128e70601, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  uiDocument: {fileID: 1189065375}
  settings: {fileID: 11400000, guid: 200c9dbb70fc7154b9a9ac64809e60fa, type: 2}
  dialogueParent: dialogue
  speechBubble: speech-bubble
  isLeftClass: speech-bubble--left
  nextButton: next-button
  leftCharacterPosition: {fileID: 2042633854}
  rightCharacterPosition: {fileID: 2071857878}
  dialogue:
  - text: Arr, welcome to Text Animations for UI Toolkit!
    isLeftSide: 1
    useTextVanishing: 0
  - text: 'Text <wave>animations</wave> right here in UI Toolkit!

      <size=50%>The
      name is a bit on the nose, I know...</size>'
    isLeftSide: 0
    useTextVanishing: 0
  - text: The name is <speed=10%><angry>fine!</angry>
    isLeftSide: 1
    useTextVanishing: 0
  - text: <shake>Uh</shake>, let's talk about <wiggle><rainbow>features</rainbow></wiggle>
      instead!
    isLeftSide: 0
    useTextVanishing: 0
  - text: Aye, <fade-in>we can add nice fade ins. <speed=50%><size-wave>Smooth</size-wave>
      like <wave a=0.12 f=0.5>the waves</wave> on a calm day.
    isLeftSide: 1
    useTextVanishing: 0
  - text: <fade-out>And fade out text! <speed=50%>Like rum after a good day o' plunderin.
    isLeftSide: 1
    useTextVanishing: 1
  - text: You can <speed=20%>slow down</speed> typewriting. Or <speed=3><shake>speeeeeeeeeeed</shake>
      iiiiiiiiiit uuuuuuuuuuuuuuup!</speed>
    isLeftSide: 0
    useTextVanishing: 0
  - text: You can change parameters for all animations, so you can go as <wave f=0.5>slow</wave>
      or as <rainbow f=5>crazy</rainbow> as you want.
    isLeftSide: 0
    useTextVanishing: 0
  - text: If ye have audio enabled, ye already heard the event system.
    isLeftSide: 1
    useTextVanishing: 0
  - text: And look at the Next / Skip button change when text has appeared completely.
    isLeftSide: 0
    useTextVanishing: 0
  - text: Aye, but there's more than that! If ye want to go crazy, ask our cannoneer
      about <bounce>custom events</bounce>.
    isLeftSide: 1
    useTextVanishing: 0
  - text: And if yer missing some customization, talk to our mate by the rum bottles.
      He'll tell ye all about custom animations.
    isLeftSide: 0
    useTextVanishing: 0
  - text: Check out the <#55AAFF><a href="https://docs.stixgames.com/text-animations">documentation</a></color>,
      it contains all the secrets of our trade. But not where our treasure is hidden.
    isLeftSide: 0
    useTextVanishing: 0
  - text: Aye, but the real treasure are <shiny>these shiny animations</shiny>!
    isLeftSide: 1
    useTextVanishing: 0
