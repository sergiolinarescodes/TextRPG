  m_Name: 
  m_EditorClassIdentifier: 
  uiDocument: {fileID: 1189065375}
  settings: {fileID: 11400000, guid: 200c9dbb70fc7154b9a9ac64809e60fa, type: 2}
  dialogueParent: dialogue
  speechBubble: speech-bubble
  isLeftClass: speech-bubble--left
  nextButton: next-button
  leftCharacterPosition: {fileID: 488043988}
  rightCharacterPosition: {fileID: 980286648}
  dialogue:
  - text: <wiggle>Hehehe</wiggle>, did the capt'n send you? You wanna hear about
      custom events?
    isLeftSide: 0
    useTextVanishing: 0
  - text: Capt'n made me stop firin' cannons. Makes it hard showing off custom events...
    isLeftSide: 0
    useTextVanishing: 0
  - text: "But I still got <shake a=0.3>BOMBS</shake>! \n1. 2. 3... <event=\"explosion-1\">Boom.
      <event=\"explosion-2\">Boom! And... <event=\"explosion-3\">BOOM! <wiggle>Hehehehe.</wiggle>"
    isLeftSide: 0
    useTextVanishing: 0
  - text: Will ye stop this <shake>NOISE</shake>?
    isLeftSide: 1
    useTextVanishing: 0
  - text: 'Aye capt''n.

      <size=70%>Once the fish be eatin'' me bones.'
    isLeftSide: 0
    useTextVanishing: 0
